# FinAlly Environment Variables
# Copy this file to .env and fill in your values.

# Required: OpenRouter API key for LLM chat functionality
# Get one at https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Massive (Polygon.io) API key for real market data
# If not set, the built-in GBM market simulator is used (recommended for most users).
# Get one at https://polygon.io/
MASSIVE_API_KEY=

# Optional: Set to "true" for deterministic mock LLM responses (used in E2E tests)
LLM_MOCK=false

# Optional: Price polling interval in seconds (default: 0.5)
POLL_INTERVAL_S=0.5

# Optional: SSE push interval in seconds (default: 0.5)
STREAM_PUSH_INTERVAL_S=0.5

# Optional: SSE client reconnection delay in milliseconds (default: 3000)
STREAM_RETRY_MS=3000
